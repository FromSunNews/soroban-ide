# ─── GitHub OAuth ────────────────────────────────────────────────
# Get this from GitHub Developer Settings -> OAuth Apps
VITE_GITHUB_CLIENT_ID=

# ─── Backend Configuration ───────────────────────────────────────
# When running in Docker, Nginx will proxy /api to this URL.
# If your backend service is named 'backend' in docker-compose, use http://backend:8080
BACKEND_URL=
